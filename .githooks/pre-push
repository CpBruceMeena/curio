#!/bin/sh
# pre-push hook — prevents direct pushes to the `main` branch.
# All changes to main must go through a feature branch + pull request.
#
# Install by running:  git config core.hooksPath .githooks

protected_branch="main"

while read local_ref local_sha remote_ref remote_sha; do
  if [ "$remote_ref" = "refs/heads/$protected_branch" ]; then
    echo "❌  Direct push to '$protected_branch' is NOT allowed."
    echo "    Create a feature branch and open a Pull Request instead."
    echo ""
    echo "    git checkout -b feat/your-feature-name"
    echo "    git add -A && git commit -m '...'"
    echo "    gh pr create --base $protected_branch"
    exit 1
  fi
done

exit 0
